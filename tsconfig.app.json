/* Para aprender más sobre el archivo de configuración de TypeScript:
https://www.typescriptlang.org/docs/handbook/tsconfig-json.html */

/* Para aprender más sobre las opciones del compilador de Angular:
https://angular.dev/reference/configs/angular-compiler-options */
{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "types": [
      "node"
    ]
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/**/*.spec.ts"
  ]
}
